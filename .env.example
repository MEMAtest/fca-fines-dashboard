DATABASE_URL=postgresql://postgres:PASSWORD@89.167.95.173:5432/fcafines
PORT=3000
FCA_YEARS=2025,2024
FCA_START_YEAR=2013
FCA_END_YEAR=2025
FCA_SINCE_DATE=2013-01-01
FCA_USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125 Safari/537.36

# Email Configuration (Resend)
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=contact@example.com

# AWS SES Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SES_REGION=eu-west-2
SES_FROM_EMAIL=alerts@example.com

# Application URLs
NEXT_PUBLIC_BASE_URL=https://fcafines.memaconsultants.com

# Optional webmaster verification tokens injected at prerender time.
# Set the real values in Vercel project environment variables, not in git.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=

# Daily Digest Configuration
DAILY_DIGEST_FROM=info@example.com
DAILY_DIGEST_TO=contact@example.com

# RegActions Editorial Engine
# Store real values in GitHub Actions secrets and the deployment environment.
# Optional only when EDITORIAL_PROVIDER=openai. OpenRouter is the default.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EDITORIAL_PROVIDER=openrouter
# Hybrid workflow accepted after a five-article trial on 12 July 2026.
EDITORIAL_OPENROUTER_APPROVED=true
EDITORIAL_DRAFT_MODEL=deepseek/deepseek-v3.2
# Optional legacy override: EDITORIAL_REGULATORY_MODEL sets both verifier stages.
EDITORIAL_INITIAL_REGULATORY_MODEL=mistralai/mistral-small-3.2-24b-instruct
EDITORIAL_FINAL_REGULATORY_MODEL=openai/gpt-4.1-mini
EDITORIAL_HEAD_MODEL=google/gemini-2.5-flash
EDITORIAL_COPY_MODEL=google/gemini-2.5-flash
EDITORIAL_VISUAL_MODEL=google/gemini-2.5-flash
EDITORIAL_IMAGE_MODEL=bytedance-seed/seedream-4.5
