SES_FROM_EMAIL=alerts@example.com

# Application URLs
NEXT_PUBLIC_BASE_URL=https://fcafines.memaconsultants.com

# Optional webmaster verification tokens injected at prerender time.
# Set the real values in Vercel project environment variables, not in git.
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=

# Daily Digest Configuration
DAILY_DIGEST_FROM=info@example.com
DAILY_DIGEST_TO=contact@example.com

# RegActions Editorial Engine
# Store real values in GitHub Actions secrets and the deployment environment.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
EDITORIAL_DRAFT_MODEL=gpt-5.5
EDITORIAL_REGULATORY_MODEL=gpt-5.5
EDITORIAL_HEAD_MODEL=gpt-5.5
EDITORIAL_COPY_MODEL=gpt-5.4-mini
EDITORIAL_VISUAL_MODEL=gpt-5.4-mini
EDITORIAL_IMAGE_MODEL=gpt-image-2
