{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "fcafines.memaconsultants.com" }
      ],
      "destination": "https://regactions.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.regactions.com" }
      ],
      "destination": "https://regactions.com/:path*",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/regulators",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|gif|svg|ico|webp|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=7776000" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|rss\\.xml|robots\\.txt|manifest\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/scrape-maintenance",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/persona-digests",
      "schedule": "30 10 * * 1"
    }
  ],
  "functions": {
    "api/cron/scrape-maintenance.ts": {
      "maxDuration": 120
    },
    "api/cron/persona-digests.ts": {
      "maxDuration": 300
    },
    "api/digest-subscribers.ts": {
      "maxDuration": 60
    }
  }
}
