{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "redirects": [
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "fcafines.memaconsultants.com" }
      ],
      "destination": "https://regactions.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "fcafines.memaconsultants.com" }
      ],
      "destination": "https://regactions.com/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "www.regactions.com" }
      ],
      "destination": "https://regactions.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.regactions.com" }
      ],
      "destination": "https://regactions.com/:path*",
      "permanent": true
    },
    {
      "source": "/blog/payments-firm-fca-aml-enforcement",
      "destination": "/blog/payments-firms-fca-aml-enforcement",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "destination": "/fines",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/ops",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/board-pack/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "private, no-store" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|gif|svg|ico|webp|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=7776000" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|rss\\.xml|robots\\.txt|manifest\\.json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'none'" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/404.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/scrape-maintenance",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/persona-digests",
      "schedule": "30 10 * * 1"
    },
    {
      "path": "/api/board-pack/retry-leads",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/process-monitors",
      "schedule": "20 8 * * *"
    },
    {
      "path": "/api/cron/country-changes-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/check-source-evidence",
      "schedule": "15 */4 * * *"
    },
    {
      "path": "/api/cron/ops-health",
      "schedule": "45 */4 * * *"
    }
  ],
  "functions": {
    "api/cron/scrape-maintenance.ts": {
      "maxDuration": 120
    },
    "api/cron/persona-digests.ts": {
      "maxDuration": 300
    },
    "api/digest-subscribers.ts": {
      "maxDuration": 60
    },
    "api/agentic/enforcement-briefing.ts": {
      "maxDuration": 60
    },
    "api/agentic/workbench.ts": {
      "maxDuration": 60
    },
    "api/board-pack/retry-leads.ts": {
      "maxDuration": 60
    },
    "api/cron/process-monitors.ts": {
      "maxDuration": 300
    },
    "api/cron/country-changes-digest.ts": {
      "maxDuration": 120
    },
    "api/cron/check-source-evidence.ts": {
      "maxDuration": 300
    },
    "api/cron/ops-health.ts": {
      "maxDuration": 120
    }
  }
}
