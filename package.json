{
  "name": "regulatory-fines-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Comprehensive UK & EU regulatory fines tracker - FCA, BaFin, AMF, and 5 more financial regulators",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --loader ts-node/esm --experimental-specifier-resolution=node server.ts",
    "start": "node --loader ts-node/esm --experimental-specifier-resolution=node server.ts",
    "build": "vite build && node --import tsx/esm scripts/generate-og-images.ts && node --import tsx/esm scripts/prerender-seo.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test --project=chromium",
    "test:e2e:all": "npm run build && playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "scrape:fines": "node --loader ts-node/esm scripts/scraper/scrapeFcaFines.ts",
    "scrape:fines:dry": "node --loader ts-node/esm scripts/scraper/scrapeFcaFines.ts --dry-run",
    "scrape:esma": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeEsma.ts').then((m) => m.main())\" --",
    "scrape:bafin": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeBafin.ts').then((m) => m.main())\" --",
    "scrape:amf": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeAmf.ts').then((m) => m.main())\" --",
    "scrape:cnmv": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeCnmv.ts').then((m) => m.main())\" --",
    "scrape:afm": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeAfm.ts').then((m) => m.main())\" --",
    "scrape:dnb": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeDnb.ts').then((m) => m.main())\" --",
    "scrape:cbi": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeCbi.ts').then((m) => m.main())\" --",
    "scrape:ecb": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeEcb.ts').then((m) => m.main())\" --",
    "scrape:dfsa": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeDfsa.ts').then((m) => m.main())\" --",
    "scrape:fsra": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeFsra.ts').then((m) => m.main())\" --",
    "scrape:cbuae": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeCbuae.ts').then((m) => m.main())\" --",
    "scrape:jfsc": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeJfsc.ts').then((m) => m.main())\" --",
    "scrape:gfsc": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeGfsc.ts').then((m) => m.main())\" --",
    "scrape:ciro": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeCiro.ts').then((m) => m.main())\" --",
    "scrape:sebi": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeSebi.ts').then((m) => m.main())\" --",
    "scrape:sec": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeSec.ts').then((m) => m.main())\" --",
    "scrape:next-eight": "node --import tsx/esm -e \"import('./scripts/scraper/scrapeNextEight.ts').then((m) => m.main())\" --",
    "verify:setup": "bash scripts/verify-setup.sh",
    "blog:monthly": "node --import tsx/esm scripts/generate-blog.ts monthly",
    "blog:topical": "node --import tsx/esm scripts/generate-blog.ts topical",
    "blog:help": "node --import tsx/esm scripts/generate-blog.ts --help"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.969.0",
    "@types/xml2js": "^0.4.14",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "classnames": "^2.5.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "date-fns": "^3.6.0",
    "dom-to-image": "^2.6.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "framer-motion": "^12.23.25",
    "fuse.js": "^7.0.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.555.0",
    "papaparse": "^5.4.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.19.0",
    "postgres": "^3.4.8",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.10.1",
    "react-use": "^17.5.0",
    "recharts": "^3.5.1",
    "resend": "^6.6.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.3.14",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.5.14",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "jsdom": "^27.3.0",
    "puppeteer": "^24.35.0",
    "satori": "^0.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.16"
  }
}
