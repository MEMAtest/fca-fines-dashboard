{
  "name": "regulatory-fines-dashboard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Comprehensive UK & EU regulatory fines tracker - FCA, BaFin, AMF, and 5 more financial regulators",
  "scripts": {
    "dev": "vite",
    "dev:api": "node --loader ts-node/esm --experimental-specifier-resolution=node server.ts",
    "start": "node --loader ts-node/esm --experimental-specifier-resolution=node server.ts",
    "build": "vite build && node --import tsx/esm scripts/generate-og-images.ts && node --import tsx/esm scripts/prerender-seo.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test --project=chromium",
    "test:e2e:all": "npm run build && playwright test",
    "test:e2e:search": "npm run build && playwright test e2e/search-experience.spec.ts --project=chromium",
    "test:e2e:search:live": "PLAYWRIGHT_BASE_URL=https://fcafines.memaconsultants.com playwright test e2e/search-live-smoke.spec.ts --project=chromium",
    "search:eval": "npx tsx scripts/evaluateSearchRelevance.ts",
    "search:eval:prod": "npx tsx scripts/evaluateSearchRelevance.ts https://fcafines.memaconsultants.com research/search-relevance-eval-set.json",
    "search:analytics:migrate": "npx tsx scripts/run-search-analytics-migration.ts",
    "search:analytics:report": "npx tsx scripts/reportSearchAnalytics.ts",
    "search:analytics:prune": "npx tsx scripts/pruneSearchAnalytics.ts",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "scrape:fines": "node --loader ts-node/esm scripts/scraper/scrapeFcaFines.ts",
